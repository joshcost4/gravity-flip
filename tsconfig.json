{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "strict": false
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules"]
}
